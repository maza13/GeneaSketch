{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "GeneaSketch",
    "version": "0.3.5",
    "identifier": "com.geneasketch.app",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:5173",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "GeneaSketch",
                "width": 1280,
                "height": 860,
                "resizable": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": [
            "msi",
            "nsis"
        ],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/icon.png",
            "icons/icon.ico"
        ]
    }
}